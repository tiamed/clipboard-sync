#!/bin/bash
#
# clipboard-sync
# Syncs clipboard bidirectionally between Linux (Wayland) and macOS
# Requirements: wl-paste, wl-copy, ssh, scp, iconv, sha256sum
#
# Configuration: ~/.config/clipboard-sync/config.ini
# State: ~/.local/state/clipboard-sync/
#

set -euo pipefail

# === CONFIGURATION DEFAULTS ===
declare -g REMOTE_USER=""
declare -g REMOTE_HOST=""
declare -g MACOS_IMAGE_COPY_PATH=""
declare -g MIN_LENGTH="1"
declare -g POLL_INTERVAL="1"
declare -g ENABLE_TEXT="true"
declare -g ENABLE_IMAGE="true"
declare -g USE_WAYLAND_WATCH="true"
declare -g MACOS_EVENT_MODE="polling"
declare -g MACOS_EVENT_FIFO="/tmp/clipboard-sync.fifo"
declare -g NOTIFICATIONS_ENABLED="true"
declare -g SSH_OPTS="-o BatchMode=yes -o StrictHostKeyChecking=no -o ConnectTimeout=10 -o ServerAliveInterval=5"
declare -g SSH_MUX_ENABLED="true"
declare -g SSH_MUX_PERSIST="300"

# === PATHS ===
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly CONFIG_FILE="$HOME/.config/clipboard-sync/config.ini"
readonly STATE_DIR="$HOME/.local/state/clipboard-sync"
readonly STATE_TEXT_HASH="$STATE_DIR/text_hash"
readonly STATE_IMAGE_HASH="$STATE_DIR/image_hash"
readonly TEMP_DIR="/tmp/clipboard_sync_$$"
readonly SSH_MUX_DIR="$HOME/.cache/clipboard-sync/ssh-mux"

# === STATE ===
LAST_TEXT_HASH=""
LAST_IMAGE_HASH=""
TEXT_WATCH_PID=""
TEXT_WATCH_FD=""
IMG_WATCH_PID=""
IMG_WATCH_FD=""
MACOS_FIFO_PID=""
MACOS_FIFO_FD=""

# === INI PARSER ===
parse_config() {
    local config_file="$1"
    local current_section=""
    
    if [[ ! -f "$config_file" ]]; then
        echo "Warning: Config file not found at $config_file, using defaults" >&2
        return 1
    fi
    
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip empty lines and comments
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        
        # Check for section headers
        if [[ "$line" =~ ^\[([^\]]+)\] ]]; then
            current_section="${BASH_REMATCH[1]}"
            continue
        fi
        
        # Parse key=value pairs
        if [[ "$line" =~ ^([^=]+)=(.*)$ ]]; then
            local key="${BASH_REMATCH[1]}"
            local value="${BASH_REMATCH[2]}"
            
            # Trim whitespace
            key=$(echo "$key" | xargs)
            value=$(echo "$value" | xargs)
            
            # Map config keys to variables based on section
            case "$current_section" in
                remote)
                    case "$key" in
                        user) REMOTE_USER="$value" ;;
                        host) REMOTE_HOST="$value" ;;
                        image_copy_path) MACOS_IMAGE_COPY_PATH="$value" ;;
                    esac
                    ;;
                sync)
                    case "$key" in
                        min_length) MIN_LENGTH="$value" ;;
                        poll_interval) POLL_INTERVAL="$value" ;;
                        enable_text) ENABLE_TEXT="$value" ;;
                        enable_image) ENABLE_IMAGE="$value" ;;
                        use_wayland_watch) USE_WAYLAND_WATCH="$value" ;;
                        macos_event_mode) MACOS_EVENT_MODE="$value" ;;
                        macos_event_fifo) MACOS_EVENT_FIFO="$value" ;;
                    esac
                    ;;
                notifications)
                    case "$key" in
                        enabled) NOTIFICATIONS_ENABLED="$value" ;;
                    esac
                    ;;
                ssh)
                    case "$key" in
                        options) SSH_OPTS="$value" ;;
                        mux_enabled) SSH_MUX_ENABLED="$value" ;;
                        mux_persist) SSH_MUX_PERSIST="$value" ;;
                    esac
                    ;;
            esac
        fi
    done < "$config_file"
    
    return 0
}

validate_config() {
    local errors=0
    
    if [[ -z "$REMOTE_USER" ]]; then
        echo "Error: remote.user not configured" >&2
        errors=$((errors + 1))
    fi
    
    if [[ -z "$REMOTE_HOST" ]]; then
        echo "Error: remote.host not configured" >&2
        errors=$((errors + 1))
    fi
    
    if [[ $errors -gt 0 ]]; then
        echo "Please configure $CONFIG_FILE" >&2
        return 1
    fi
    
    return 0
}

# === SETUP ===
setup() {
    mkdir -p "$TEMP_DIR"
    chmod 700 "$TEMP_DIR" 2>/dev/null || true
    
    mkdir -p "$STATE_DIR"
    chmod 700 "$STATE_DIR" 2>/dev/null || true
    
    # Setup SSH multiplexing directory
    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        mkdir -p "$SSH_MUX_DIR"
        chmod 700 "$SSH_MUX_DIR" 2>/dev/null || true
    fi
    
    touch "$STATE_TEXT_HASH" "$STATE_IMAGE_HASH"
    LAST_TEXT_HASH=$(cat "$STATE_TEXT_HASH" 2>/dev/null || echo "")
    LAST_IMAGE_HASH=$(cat "$STATE_IMAGE_HASH" 2>/dev/null || echo "")
}

# Get SSH socket path for current connection
get_ssh_socket() {
    # Use shorter hash to avoid path length issues with Unix domain sockets
    # OpenSSH has a ~100 character limit on the ControlPath
    local conn_string="${REMOTE_USER}@${REMOTE_HOST}"
    local socket_hash
    socket_hash=$(echo -n "$conn_string" | md5sum | awk '{print $1}' | cut -c1-16)
    echo "$SSH_MUX_DIR/$socket_hash"
}

# Ensure SSH master connection is established (for multiplexing)
ensure_ssh_master() {
    if [[ "$SSH_MUX_ENABLED" != "true" ]]; then
        return 0
    fi
    
    local socket
    socket=$(get_ssh_socket)
    
    # Check if master connection already exists and is alive
    if [[ -S "$socket" ]]; then
        # Verify it's still alive
        if ssh -O check -S "$socket" "$REMOTE_USER@$REMOTE_HOST" 2>/dev/null; then
            return 0
        fi
        # Dead socket, remove it
        rm -f "$socket"
    elif [[ -e "$socket" ]]; then
        # Regular file exists at socket path (stale from previous failed attempt)
        # Remove it before creating new socket
        rm -f "$socket"
    fi
    
    # Establish new master connection in background
    ssh -fN -M -S "$socket" \
        -o ControlPersist="$SSH_MUX_PERSIST" \
        $SSH_OPTS \
        "$REMOTE_USER@$REMOTE_HOST" 2>/dev/null
    
    # Wait for socket to be created (up to 5 seconds)
    local waited=0
    while [[ ! -S "$socket" ]] && [[ $waited -lt 50 ]]; do
        sleep 0.1
        waited=$((waited + 1))
    done
    
    [[ -S "$socket" ]]
}

cleanup() {
    rm -rf "$TEMP_DIR" 2>/dev/null || true

    stop_wayland_watchers
    stop_macos_fifo_reader

    # Close SSH master connection if we started it
    if [[ "$SSH_MUX_ENABLED" == "true" ]] && [[ -n "${REMOTE_USER:-}" ]] && [[ -n "${REMOTE_HOST:-}" ]]; then
        local socket
        socket=$(get_ssh_socket 2>/dev/null) || return
        if [[ -S "$socket" ]]; then
            ssh -O exit -S "$socket" "$REMOTE_USER@$REMOTE_HOST" 2>/dev/null || true
        fi
    fi
}

# === UTILITIES ===

# Ensure string is valid UTF-8 and strip null bytes
ensure_utf8() {
    local input="$1"
    echo -n "$input" | iconv -f UTF-8 -t UTF-8 -c 2>/dev/null | tr -d '\000' || echo -n "$input"
}

# Get SHA-256 hash of text (trailing whitespace trimmed)
get_text_hash() {
    echo -n "$1" | sed 's/[[:space:]]*$//' | sha256sum | awk '{print $1}'
}

# Get SHA-256 hash of file
get_file_hash() {
    sha256sum "$1" | awk '{print $1}'
}

# Escape notification content for notify-send
escape_notification() {
    local text="$1"
    # Prepend space to prevent leading dash interpretation
    echo " $text" | sed 's/%/%%/g; s/\\/\\\\/g; s/"/\\"/g'
}

# === LOGGING ===
# All output goes to stderr so systemd/journalctl captures it.
log() {
    local level="$1"
    shift
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$level] $*" >&2
}

log_info()  { log "INFO" "$@"; }
log_warn()  { log "WARN" "$@"; }
log_error() { log "ERROR" "$@"; }

# Check SSH connection health
check_connection() {
    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        ensure_ssh_master || return 1
        local socket
        socket=$(get_ssh_socket)
        ssh -O check -S "$socket" "$REMOTE_USER@$REMOTE_HOST" 2>/dev/null
    else
        ssh -n $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" "true" 2>/dev/null
    fi
}

# === PUSH OPERATIONS (Linux → macOS) ===

push_text_to_macos() {
    local text="$1"
    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        local socket
        socket=$(get_ssh_socket)
        printf '%s' "$text" | ssh -S "$socket" -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" \
            "export LC_CTYPE=en_US.UTF-8; pbcopy" 2>/dev/null
    else
        printf '%s' "$text" | ssh -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" \
            "export LC_CTYPE=en_US.UTF-8; pbcopy" 2>/dev/null
    fi
}

push_image_to_macos() {
    local img="$1"
    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        local socket
        socket=$(get_ssh_socket)
        scp -o ControlPath="$socket" -q $SSH_OPTS "$img" "$REMOTE_USER@$REMOTE_HOST:/tmp/clipboard_sync.png" 2>/dev/null || return 1
        ssh -S "$socket" -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" \
            "$MACOS_IMAGE_COPY_PATH /tmp/clipboard_sync.png && rm -f /tmp/clipboard_sync.png" 2>/dev/null
    else
        scp -q $SSH_OPTS "$img" "$REMOTE_USER@$REMOTE_HOST:/tmp/clipboard_sync.png" 2>/dev/null || return 1
        ssh -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" \
            "$MACOS_IMAGE_COPY_PATH /tmp/clipboard_sync.png && rm -f /tmp/clipboard_sync.png" 2>/dev/null
    fi
}

# === PULL OPERATIONS (macOS → Linux) ===

pull_text_from_macos() {
    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        local socket
        socket=$(get_ssh_socket)
        ssh -S "$socket" -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" \
            "export LC_CTYPE=en_US.UTF-8; pbpaste" 2>/dev/null || echo ""
    else
        ssh -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" \
            "export LC_CTYPE=en_US.UTF-8; pbpaste" 2>/dev/null || echo ""
    fi
}

pull_image_from_macos() {
    echo "[DEBUG] pull_image_from_macos: starting" >&2
    local tmp="$TEMP_DIR/macos_image_$$.png"
    local mac_path

    # Try to copy image from macOS
    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        local socket
        socket=$(get_ssh_socket)
        echo "[DEBUG] pull_image_from_macos: using mux socket, running imagecopy on remote" >&2
        mac_path=$(ssh -S "$socket" -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" \
            "$MACOS_IMAGE_COPY_PATH -o /tmp/clipboard_pull_$$.png 2>/dev/null && echo /tmp/clipboard_pull_$$.png" 2>/dev/null) || return 1
    else
        echo "[DEBUG] pull_image_from_macos: using direct ssh, running imagecopy on remote" >&2
        mac_path=$(ssh -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" \
            "$MACOS_IMAGE_COPY_PATH -o /tmp/clipboard_pull_$$.png 2>/dev/null && echo /tmp/clipboard_pull_$$.png" 2>/dev/null) || return 1
    fi
    echo "[DEBUG] pull_image_from_macos: imagecopy returned mac_path='$mac_path'" >&2

    # Validate returned path
    if [[ -z "$mac_path" ]] || [[ "$mac_path" == *\** ]] || [[ "$mac_path" != /tmp/* ]]; then
        echo "[DEBUG] pull_image_from_macos: invalid mac_path, returning early" >&2
        return 1
    fi

    echo "[DEBUG] pull_image_from_macos: scp copying from remote to $tmp" >&2
    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        local socket
        socket=$(get_ssh_socket)
        scp -o ControlPath="$socket" -q $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST:$mac_path" "$tmp" 2>/dev/null || return 1
        ssh -S "$socket" -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" "rm -f $mac_path" 2>/dev/null || true
    else
        scp -q $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST:$mac_path" "$tmp" 2>/dev/null || return 1
        ssh -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" "rm -f $mac_path" 2>/dev/null || true
    fi
    echo "[DEBUG] pull_image_from_macos: scp done" >&2

    if [[ -s "$tmp" ]]; then
        echo "[DEBUG] pull_image_from_macos: returning $tmp" >&2
        echo "$tmp"
    else
        echo "[DEBUG] pull_image_from_macos: empty file, returning failure" >&2
        rm -f "$tmp"
        return 1
    fi
}

# === NOTIFICATIONS ===

notify_linux() {
    local title="$1"
    local content="$2"
    
    if [[ "$NOTIFICATIONS_ENABLED" != "true" ]]; then
        return
    fi
    
    local escaped_title escaped_content

    escaped_title=$(escape_notification "$title")
    escaped_content=$(escape_notification "$content")

    notify-send "$escaped_title" "$escaped_content" 2>/dev/null || true
}

notify_macos() {
    local title="$1"
    local content="$2"
    
    if [[ "$NOTIFICATIONS_ENABLED" != "true" ]]; then
        return
    fi
    
    local truncated=""

    if [[ ${#content} -gt 100 ]]; then
        truncated="${content:0:100}..."
    else
        truncated="$content"
    fi

    truncated=$(printf '%s' "$truncated" | sed 's/\\/\\\\/g; s/"/\\"/g')
    title=$(printf '%s' "$title" | sed 's/\\/\\\\/g; s/"/\\"/g')

    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        local socket
        socket=$(get_ssh_socket)
        printf 'display notification "%s" with title "%s"' "$truncated" "$title" | \
            ssh -S "$socket" -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" \
            "export LC_CTYPE=en_US.UTF-8; osascript -" 2>/dev/null || true
    else
        printf 'display notification "%s" with title "%s"' "$truncated" "$title" | \
            ssh -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" \
            "export LC_CTYPE=en_US.UTF-8; osascript -" 2>/dev/null || true
    fi
}

# === LINUX POLLING ===

poll_linux_text() {
    if [[ "$ENABLE_TEXT" != "true" ]]; then
        return
    fi
    
    local linux_text
    linux_text=$(wl-paste -t text/plain 2>/dev/null || echo "")

    if [[ ${#linux_text} -lt $MIN_LENGTH ]]; then
        return
    fi

    linux_text=$(ensure_utf8 "$linux_text")
    local current_hash
    current_hash=$(get_text_hash "$linux_text")

    if [[ "$current_hash" != "$LAST_TEXT_HASH" ]]; then
        if check_connection && push_text_to_macos "$linux_text"; then
            LAST_TEXT_HASH="$current_hash"
            echo "$LAST_TEXT_HASH" > "$STATE_TEXT_HASH"
            echo "[$(date '+%H:%M:%S')] Text pushed to macOS"
            notify_macos "Clipboard Sync" "$linux_text"
        fi
    fi
}

poll_linux_image() {
    if [[ "$ENABLE_IMAGE" != "true" ]]; then
        return
    fi
    
    local image_type
    image_type=$(wl-paste --list-types 2>/dev/null | grep -m1 "image/" || echo "")

    if [[ -z "$image_type" ]]; then
        return
    fi

    local tmp_img="$TEMP_DIR/linux_image_$$.${image_type#image/}"
    if ! wl-paste --type "$image_type" > "$tmp_img" 2>/dev/null; then
        rm -f "$tmp_img"
        return
    fi

    if [[ ! -s "$tmp_img" ]]; then
        rm -f "$tmp_img"
        return
    fi

    local current_hash
    current_hash=$(get_file_hash "$tmp_img")

    if [[ "$current_hash" != "$LAST_IMAGE_HASH" ]]; then
        if check_connection && push_image_to_macos "$tmp_img"; then
            LAST_IMAGE_HASH="$current_hash"
            echo "$LAST_IMAGE_HASH" > "$STATE_IMAGE_HASH"
            echo "[$(date '+%H:%M:%S')] Image pushed to macOS"
            notify_macos "Clipboard Sync" "Image received from Linux"
        fi
    fi

    rm -f "$tmp_img"
}

# === MACOS POLLING ===

poll_macos_text() {
    if [[ "$ENABLE_TEXT" != "true" ]]; then
        return
    fi
    
    local mac_text
    mac_text=$(pull_text_from_macos)

    if [[ ${#mac_text} -lt $MIN_LENGTH ]]; then
        return
    fi

    mac_text=$(ensure_utf8 "$mac_text")
    local current_hash
    current_hash=$(get_text_hash "$mac_text")

    if [[ "$current_hash" != "$LAST_TEXT_HASH" ]]; then
        if printf '%s' "$mac_text" | wl-copy -t text/plain 2>/dev/null; then
            LAST_TEXT_HASH="$current_hash"
            echo "$LAST_TEXT_HASH" > "$STATE_TEXT_HASH"
            echo "[$(date '+%H:%M:%S')] Text pulled from macOS"
            notify_linux "Clipboard Sync" "$mac_text"
        fi
    fi
}

poll_macos_image() {
    if [[ "$ENABLE_IMAGE" != "true" ]]; then
        return
    fi
    
    local tmp_mac_img
    tmp_mac_img=$(pull_image_from_macos) || tmp_mac_img=""

    if [[ ! -f "$tmp_mac_img" ]]; then
        return
    fi

    local current_hash
    current_hash=$(get_file_hash "$tmp_mac_img")

    if [[ "$current_hash" != "$LAST_IMAGE_HASH" ]]; then
        if wl-copy --type image/png < "$tmp_mac_img" 2>/dev/null; then
            LAST_IMAGE_HASH="$current_hash"
            echo "$LAST_IMAGE_HASH" > "$STATE_IMAGE_HASH"
            echo "[$(date '+%H:%M:%S')] Image pulled from macOS"
            notify_linux "Clipboard Sync [IMAGE]" "Image copied"
        fi
    fi

    rm -f "$tmp_mac_img"
}

# === WAYLAND EVENT WATCHERS ===

wl_paste_watch_supported() {
    command -v wl-paste >/dev/null 2>&1 || return 1
    wl-paste --help 2>&1 | grep -q -- '--watch'
}

wayland_watch_available() {
    if [[ "$USE_WAYLAND_WATCH" != "true" ]]; then
        return 1
    fi
    if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
        log_warn "WAYLAND_DISPLAY not set, falling back to polling"
        return 1
    fi
    if ! command -v wl-paste >/dev/null 2>&1; then
        log_warn "wl-paste not found, falling back to polling"
        return 1
    fi
    if ! wl_paste_watch_supported; then
        log_warn "wl-paste does not support --watch, falling back to polling"
        return 1
    fi
    return 0
}

start_wayland_watchers() {
    # Use differently-named variables for the coprocess because bash unsets the
    # special coproc PID variable once the child is reaped.
    coproc _TEXT_WATCH { exec wl-paste --type text --watch printf 'TEXT_CHANGED\n'; }
    TEXT_WATCH_PID=${_TEXT_WATCH_PID:-}
    TEXT_WATCH_FD=${_TEXT_WATCH[0]:-}

    coproc _IMG_WATCH { exec wl-paste --type image/png --watch printf 'IMG_CHANGED\n'; }
    IMG_WATCH_PID=${_IMG_WATCH_PID:-}
    IMG_WATCH_FD=${_IMG_WATCH[0]:-}

    sleep 0.2
    if [[ -z "$TEXT_WATCH_PID" ]] || [[ -z "$IMG_WATCH_PID" ]] || \
       ! kill -0 "$TEXT_WATCH_PID" 2>/dev/null || ! kill -0 "$IMG_WATCH_PID" 2>/dev/null; then
        log_error "wl-paste watcher(s) failed to start"
        stop_wayland_watchers
        return 1
    fi
    log_info "Wayland event watchers started (text=$TEXT_WATCH_PID image=$IMG_WATCH_PID)"
    return 0
}

stop_wayland_watchers() {
    local pid
    for pid in "$TEXT_WATCH_PID" "$IMG_WATCH_PID"; do
        if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
            sleep 0.2
            kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
        fi
    done
    TEXT_WATCH_PID=""
    IMG_WATCH_PID=""
}

run_watch_loop() {
    local last_watchdog last_macos_poll now
    last_watchdog=$(date +%s)
    last_macos_poll=$(date +%s)

    while true; do
        local changed=false event=""

        # Drain all available text events
        while read -r -t 0 -u "$TEXT_WATCH_FD" _ 2>/dev/null; do
            read -r -u "$TEXT_WATCH_FD" event
            if [[ "$event" == "TEXT_CHANGED" ]]; then
                poll_linux_text
                changed=true
            fi
        done

        # Drain all available image events
        while read -r -t 0 -u "$IMG_WATCH_FD" _ 2>/dev/null; do
            read -r -u "$IMG_WATCH_FD" event
            if [[ "$event" == "IMG_CHANGED" ]]; then
                poll_linux_image
                changed=true
            fi
        done

        # Drain all available macOS FIFO events
        if [[ -n "$MACOS_FIFO_FD" ]]; then
            while read -r -t 0 -u "$MACOS_FIFO_FD" _ 2>/dev/null; do
                read -r -u "$MACOS_FIFO_FD" event
                handle_macos_fifo_event
                changed=true
            done
        fi

        # Poll macOS clipboard on the configured interval as a safety net.
        now=$(date +%s)
        if [[ $((now - last_macos_poll)) -ge $POLL_INTERVAL ]]; then
            poll_macos_text
            poll_macos_image
            last_macos_poll=$now
        fi

        # Watchdog: check watcher health every 5s using elapsed time.
        if [[ $((now - last_watchdog)) -ge 5 ]]; then
            if ! kill -0 "$TEXT_WATCH_PID" 2>/dev/null || ! kill -0 "$IMG_WATCH_PID" 2>/dev/null; then
                log_warn "Wayland watcher died, restarting..."
                stop_wayland_watchers
                if ! start_wayland_watchers; then
                    log_warn "Wayland watcher restart failed, falling back to polling"
                    return 1
                fi
            fi
            if [[ -n "$MACOS_FIFO_PID" ]] && ! kill -0 "$MACOS_FIFO_PID" 2>/dev/null; then
                log_warn "macOS FIFO reader died, restarting..."
                stop_macos_fifo_reader
                start_macos_fifo_reader || true
            fi
            last_watchdog=$now
        fi

        if ! $changed; then
            sleep 0.2
        fi
    done
}

run_polling_loop() {
    while true; do
        poll_linux_text
        poll_linux_image
        poll_macos_text
        poll_macos_image
        sleep "$POLL_INTERVAL"
    done
}

# === MACOS FIFO EVENT READER (optional) ===

macos_fifo_available() {
    if [[ "$MACOS_EVENT_MODE" != "fifo" ]]; then
        return 1
    fi
    if [[ -z "$MACOS_EVENT_FIFO" ]]; then
        return 1
    fi
    return 0
}

start_macos_fifo_reader() {
    coproc _MACOS_FIFO { exec ssh -T $SSH_OPTS "$REMOTE_USER@$REMOTE_HOST" "cat '$MACOS_EVENT_FIFO'"; }
    MACOS_FIFO_PID=${_MACOS_FIFO_PID:-}
    MACOS_FIFO_FD=${_MACOS_FIFO[0]:-}

    sleep 0.2
    if [[ -z "$MACOS_FIFO_PID" ]] || ! kill -0 "$MACOS_FIFO_PID" 2>/dev/null; then
        log_warn "macOS FIFO reader failed to start"
        stop_macos_fifo_reader
        return 1
    fi
    log_info "macOS FIFO reader started (pid $MACOS_FIFO_PID)"
    return 0
}

stop_macos_fifo_reader() {
    if [[ -n "${MACOS_FIFO_PID:-}" ]] && kill -0 "$MACOS_FIFO_PID" 2>/dev/null; then
        kill "$MACOS_FIFO_PID" 2>/dev/null || true
        sleep 0.2
        kill -0 "$MACOS_FIFO_PID" 2>/dev/null && kill -9 "$MACOS_FIFO_PID" 2>/dev/null || true
        wait "$MACOS_FIFO_PID" 2>/dev/null || true
    fi
    MACOS_FIFO_PID=""
}

handle_macos_fifo_event() {
    # The daemon sends the actual content, but for now we use the event purely
    # as a trigger to pull the latest clipboard from macOS via SSH. A future
    # optimization could decode the embedded content and skip the SSH round-trip.
    poll_macos_text
    poll_macos_image
}

# === ONE-SHOT COMMANDS ===

cmd_sync_to() {
    # One-shot push Linux clipboard to macOS
    # Establish master connection for multiplexing
    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        ensure_ssh_master || {
            echo "Warning: SSH multiplexing setup failed, using direct connection" >&2
            SSH_MUX_ENABLED="false"
        }
    fi
    
    if ! check_connection; then
        echo "Error: cannot connect to $REMOTE_USER@$REMOTE_HOST" >&2
        return 1
    fi

    # Try image first
    if [[ "$ENABLE_IMAGE" == "true" ]]; then
        local image_type
        image_type=$(wl-paste --list-types 2>/dev/null | grep -m1 "image/" || echo "")

        if [[ -n "$image_type" ]]; then
            local tmp_img="$TEMP_DIR/sync_to_image_$$.${image_type#image/}"
            if wl-paste --type "$image_type" > "$tmp_img" 2>/dev/null && [[ -s "$tmp_img" ]]; then
                if push_image_to_macos "$tmp_img"; then
                    rm -f "$tmp_img"
                    notify_macos "Clipboard Sync" "Image received from Linux"
                    echo "Image synced to macOS"
                    return 0
                else
                    rm -f "$tmp_img"
                    echo "Error: failed to push image to macOS" >&2
                    return 1
                fi
            fi
            rm -f "$tmp_img"
        fi
    fi

    # Fall back to text
    if [[ "$ENABLE_TEXT" == "true" ]]; then
        local linux_text
        linux_text=$(wl-paste -t text/plain 2>/dev/null || echo "")

        if [[ ${#linux_text} -ge $MIN_LENGTH ]]; then
            linux_text=$(ensure_utf8 "$linux_text")
            if push_text_to_macos "$linux_text"; then
                notify_macos "Clipboard Sync" "$linux_text"
                echo "Text synced to macOS (${#linux_text} chars)"
                return 0
            else
                echo "Error: failed to push text to macOS" >&2
                return 1
            fi
        fi
    fi

    echo "Nothing to sync (clipboard empty or below min length)"
    return 0
}

cmd_sync_from() {
    # One-shot pull macOS clipboard to Linux
    # Establish master connection for multiplexing
    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        ensure_ssh_master || {
            echo "Warning: SSH multiplexing setup failed, using direct connection" >&2
            SSH_MUX_ENABLED="false"
        }
    fi
    
    if ! check_connection; then
        echo "Error: cannot connect to $REMOTE_USER@$REMOTE_HOST" >&2
        return 1
    fi

    # Try image first
    if [[ "$ENABLE_IMAGE" == "true" ]]; then
        local tmp_mac_img
        tmp_mac_img=$(pull_image_from_macos) || tmp_mac_img=""

        if [[ -n "$tmp_mac_img" ]] && [[ -f "$tmp_mac_img" ]]; then
            if wl-copy --type image/png < "$tmp_mac_img" 2>/dev/null; then
                rm -f "$tmp_mac_img"
                notify_linux "Clipboard Sync [IMAGE]" "Image copied"
                echo "Image synced from macOS"
                return 0
            else
                rm -f "$tmp_mac_img"
                echo "Warning: image pull succeeded but wl-copy failed, trying text" >&2
            fi
        else
            [[ -n "$tmp_mac_img" ]] && rm -f "$tmp_mac_img"
        fi
    fi

    # Fall back to text
    if [[ "$ENABLE_TEXT" == "true" ]]; then
        local mac_text
        mac_text=$(pull_text_from_macos)

        if [[ ${#mac_text} -ge $MIN_LENGTH ]]; then
            mac_text=$(ensure_utf8 "$mac_text")
            if printf '%s' "$mac_text" | wl-copy -t text/plain 2>/dev/null; then
                notify_linux "Clipboard Sync" "$mac_text"
                echo "Text synced from macOS (${#mac_text} chars)"
                return 0
            else
                echo "Error: failed to copy text to Linux clipboard" >&2
                return 1
            fi
        fi
    fi

    echo "Nothing to sync from macOS (clipboard empty or below min length)"
    return 0
}

# === USAGE ===

show_usage() {
    cat << 'EOF'
Usage: clipboard-sync [COMMAND]

Commands:
  (none)     Run in continuous polling daemon mode
  sync-to    Push Linux clipboard to macOS (one-shot, auto-detect type)
  sync-from  Pull macOS clipboard to Linux (one-shot, auto-detect type)

Options:
  -h, --help  Show this help message

Configuration: ~/.config/clipboard-sync/config.ini
State:        ~/.local/state/clipboard-sync/

Examples:
  clipboard-sync              # Start continuous sync daemon
  clipboard-sync sync-to      # Immediately push Linux clipboard to macOS
  clipboard-sync sync-from    # Immediately pull macOS clipboard to Linux

Keyboard shortcut examples (for sway/i3/hyprland):
  bindsym $mod+Shift+c exec clipboard-sync sync-to
  bindsym $mod+Shift+v exec clipboard-sync sync-from
EOF
}

# === MAIN LOOP ===

run_daemon() {
    setup

    # Establish SSH master connection for multiplexing
    if [[ "$SSH_MUX_ENABLED" == "true" ]]; then
        echo "Establishing SSH master connection..."
        if ensure_ssh_master; then
            echo "SSH multiplexing enabled (persist: ${SSH_MUX_PERSIST}s)"
        else
            echo "Warning: SSH multiplexing setup failed, falling back to direct connections"
            SSH_MUX_ENABLED="false"
        fi
    fi

    log_info "Clipboard sync started (Linux ←→ macOS)"
    log_info "Remote: $REMOTE_USER@$REMOTE_HOST"
    log_info "Config: $CONFIG_FILE"
    log_info "State: $STATE_DIR"
    log_info "Text sync: $ENABLE_TEXT"
    log_info "Image sync: $ENABLE_IMAGE"
    log_info "Polling interval: ${POLL_INTERVAL}s"

    local use_watch=false
    if wayland_watch_available && start_wayland_watchers; then
        use_watch=true
        log_info "Using Wayland event-driven monitoring"
    else
        log_info "Using polling mode for Linux clipboard"
    fi

    if macos_fifo_available && start_macos_fifo_reader; then
        log_info "Using macOS FIFO event-driven monitoring"
    fi

    if $use_watch; then
        run_watch_loop || run_polling_loop
    else
        run_polling_loop
    fi
}

main() {
    # Parse configuration
    parse_config "$CONFIG_FILE" || true

    case "${1:-}" in
        sync-to)
            # Don't register cleanup for one-shot commands - keep master connection alive
            mkdir -p "$TEMP_DIR"
            chmod 700 "$TEMP_DIR" 2>/dev/null || true
            validate_config || exit 1
            cmd_sync_to
            exit $?
            ;;
        sync-from)
            # Don't register cleanup for one-shot commands - keep master connection alive
            mkdir -p "$TEMP_DIR"
            chmod 700 "$TEMP_DIR" 2>/dev/null || true
            validate_config || exit 1
            cmd_sync_from
            exit $?
            ;;
        -h|--help)
            show_usage
            exit 0
            ;;
        "")
            # Daemon mode (default, backward compatible)
            trap cleanup EXIT INT TERM
            validate_config || exit 1
            run_daemon
            ;;
        *)
            echo "Unknown command: $1" >&2
            show_usage >&2
            exit 1
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
